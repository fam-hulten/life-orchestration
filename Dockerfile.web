FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/LifeOrchestration.Core/LifeOrchestration.Core.csproj src/LifeOrchestration.Core/
COPY src/LifeOrchestration.Web/LifeOrchestration.Web.csproj src/LifeOrchestration.Web/

RUN dotnet restore src/LifeOrchestration.Web/LifeOrchestration.Web.csproj

COPY src/ src/
RUN dotnet publish src/LifeOrchestration.Web/LifeOrchestration.Web.csproj -c Release -o /app/static

FROM nginx:alpine
COPY --from=build /app/static/wwwroot /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
