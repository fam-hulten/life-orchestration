@page "/"
@using System.Net.Http.Json
@using LifeOrchestration.Core.Entities
@using TaskStatus = LifeOrchestration.Core.Entities.TaskStatus

<PageTitle>Tasks - Life Orchestration</PageTitle>

<div class="container mt-4">
    <h1>📋 Life Orchestration</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <h3>Tasks</h3>
            
            @if (tasks == null)
            {
                <p>Laddar...</p>
            }
            else if (!tasks.Any())
            {
                <p class="text-muted">Inga tasks ännu. Skapa en nedan!</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var task in tasks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <span class="me-2">@GetStatusIcon(task.Status)</span>
                                <strong>@task.Title</strong>
                                <span class="text-muted ms-2">— @task.Assignee</span>
                            </div>
                            <div class="btn-group btn-group-sm">
                                @if (task.Status != TaskStatus.Done)
                                {
                                    <button class="btn btn-success btn-sm" @onclick="() => UpdateStatus(task.Id, TaskStatus.Done)">✓</button>
                                }
                                @if (task.Status == TaskStatus.Todo)
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => UpdateStatus(task.Id, TaskStatus.InProgress)">▶</button>
                                }
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteTask(task.Id)">✕</button>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>➕ New Task</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <input class="form-control" placeholder="Titel" @bind="newTitle" />
                    </div>
                    <div class="mb-2">
                        <select class="form-select" @bind="newAssignee">
                            <option value="">Välj ansvarig...</option>
                            <option value="Robert">Robert</option>
                            <option value="Lilly">Lilly</option>
                            <option value="Johanna">Johanna</option>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="CreateTask" disabled="@(string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newAssignee))">
                        Skapa
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TaskItem>? tasks;
    private string newTitle = "";
    private string newAssignee = "";
    

    
    private HttpClient httpClient = new() { BaseAddress = new Uri("http://192.168.1.194:3080") };
    
    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }
    
    private async Task LoadTasks()
    {
        try
        {
            tasks = await httpClient.GetFromJsonAsync<List<TaskItem>>("/api/tasks");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
        }
    }
    
    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newAssignee)) return;
        
        try
        {
            var response = await httpClient.PostAsJsonAsync("/api/tasks", new { Title = newTitle, Assignee = newAssignee });
            if (response.IsSuccessStatusCode)
            {
                newTitle = "";
                newAssignee = "";
                await LoadTasks();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating task: {ex.Message}");
        }
    }
    
    private async Task UpdateStatus(int id, TaskStatus status)
    {
        try
        {
            await httpClient.PatchAsJsonAsync($"/api/tasks/{id}", new { Status = status });
            await LoadTasks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating task: {ex.Message}");
        }
    }
    
    private async Task DeleteTask(int id)
    {
        try
        {
            await httpClient.DeleteAsync($"/api/tasks/{id}");
            await LoadTasks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting task: {ex.Message}");
        }
    }
    
    private string GetStatusIcon(TaskStatus status) => status switch
    {
        TaskStatus.Todo => "[ ]",
        TaskStatus.InProgress => "[~]",
        TaskStatus.Done => "[✓]",
        _ => "[?]"
    };
}
