@page "/"
@using System.Net.Http.Json
@using LifeOrchestration.Core.Entities
@using TaskStatus = LifeOrchestration.Core.Entities.TaskStatus
@inject HttpClient Http

<PageTitle>Tasks - Life Orchestration</PageTitle>

<div class="container mt-4">
    <h1>📋 Life Orchestration</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <h3>Tasks</h3>
            
            @if (tasks == null)
            {
                <p>Laddar...</p>
            }
            else if (!tasks.Any())
            {
                <p class="text-muted">Inga tasks ännu. Skapa en nedan!</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var task in tasks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <span class="me-2">@GetStatusIcon(task.Status)</span>
                                <strong>@task.Title</strong>
                                <span class="text-muted ms-2">— @task.Assignee</span>
                            </div>
                            <div class="btn-group btn-group-sm">
                                @if (task.Status != TaskStatus.Done)
                                {
                                    <button type="button" class="btn btn-success btn-sm" 
                                        @onclick="() => UpdateStatus(task.Id, TaskStatus.Done)">✓</button>
                                }
                                @if (task.Status == TaskStatus.Todo)
                                {
                                    <button type="button" class="btn btn-primary btn-sm" 
                                        @onclick="() => UpdateStatus(task.Id, TaskStatus.InProgress)">▶</button>
                                }
                                <button type="button" class="btn btn-danger btn-sm" 
                                    @onclick="() => DeleteTask(task.Id)">✕</button>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>➕ New Task</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <input type="text" class="form-control" placeholder="Titel" 
                            @bind="newTitle" @bind:event="oninput" />
                    </div>
                    <div class="mb-2">
                        <select class="form-select" @bind="newAssignee" @bind:event="onchange">
                            <option value="">Välj ansvarig...</option>
                            <option value="Robert">Robert</option>
                            <option value="Lilly">Lilly</option>
                            <option value="Johanna">Johanna</option>
                        </select>
                    </div>
                    <button type="button" class="btn btn-primary w-100" @onclick="CreateTask">
                        Skapa
                    </button>
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="mt-2 alert alert-info">@statusMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TaskItem>? tasks;
    private string newTitle = "";
    private string newAssignee = "";
    private string statusMessage = "";
    
    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }
    
    private async Task LoadTasks()
    {
        try
        {
            tasks = await Http.GetFromJsonAsync<List<TaskItem>>("/api/tasks");
            statusMessage = "";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newAssignee))
        {
            statusMessage = "Titel och ansvarig krävs!";
            return;
        }
        
        try
        {
            var response = await Http.PostAsJsonAsync("/api/tasks", new { Title = newTitle, Assignee = newAssignee });
            if (response.IsSuccessStatusCode)
            {
                newTitle = "";
                newAssignee = "";
                statusMessage = "Skapad!";
                await LoadTasks();
            }
            else
            {
                statusMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task UpdateStatus(int id, TaskStatus status)
    {
        try
        {
            await Http.PatchAsJsonAsync($"/api/tasks/{id}", new { Status = status });
            await LoadTasks();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task DeleteTask(int id)
    {
        try
        {
            await Http.DeleteAsync($"/api/tasks/{id}");
            await LoadTasks();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
    
    private string GetStatusIcon(TaskStatus status) => status switch
    {
        TaskStatus.Todo => "[ ]",
        TaskStatus.InProgress => "[~]",
        TaskStatus.Done => "[✓]",
        _ => "[?]"
    };
}
